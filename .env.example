SQL_AGENT_ENV=production
SQL_AGENT_APP_NAME=SQL Agent
SQL_AGENT_APP_VERSION=0.1.0
SQL_AGENT_DATABASE_URL=mssql+pyodbc://localhost/visaDB_copy?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes
SQL_AGENT_OLLAMA_MODEL=qwen3:8b
SQL_AGENT_HOST=127.0.0.1
SQL_AGENT_PORT=8000
SQL_AGENT_RELOAD=false
SQL_AGENT_LOG_LEVEL=info
SQL_AGENT_AGENT_TIMEOUT_SECONDS=120
SQL_AGENT_MAX_QUESTION_CHARS=2000
SQL_AGENT_MAX_REQUEST_BYTES=16384
SQL_AGENT_ACCESS_KEY=
SQL_AGENT_ALLOWED_HOSTS=127.0.0.1,localhost
SQL_AGENT_ALLOWED_ORIGINS=
